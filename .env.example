# =============================================================
# MF Quản lý Đơn - Environment Variables Template
# Copy file này thành .env ở thư mục gốc project
# =============================================================

# --- Database ---
# ⚠️ QUAN TRỌNG: Khi chạy Docker, hostname phải là "postgres" (tên service)
# Khi dev local (không Docker), dùng "localhost"
DATABASE_URL="postgresql://oms_user:oms_pass_2025@postgres:5432/oms_db?schema=public"

# Biến riêng cho docker-compose (PostgreSQL container init)
POSTGRES_USER=oms_user
POSTGRES_PASSWORD=oms_pass_2025
POSTGRES_DB=oms_db

# --- JWT ---
JWT_ACCESS_SECRET="change-me-access-secret-very-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret-very-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- API ---
PORT=3001

# --- Web ---
NEXT_PUBLIC_API_URL="https://oms.xuanlockontum.com"
WEB_URL="http://web:3000"

# --- Vietnam Provinces API ---
VN_PROVINCES_API_URL="https://provinces.open-api.vn/api/v2"
