{
  "name": "mf-quanlydon",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @mf/database prisma:generate",
    "db:migrate": "pnpm --filter @mf/database prisma:migrate",
    "db:seed": "pnpm --filter @mf/database prisma:seed",
    "db:studio": "pnpm --filter @mf/database prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
